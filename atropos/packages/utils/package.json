{
  "name": "@delhivery/utilities",
  "description": "Common utilities for typescript/cdk applications",
  "version": "0.1.0",
  "license": "MIT",
  "directories": {
    "source": "./src",
    "test": "./test"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist && rimraf cdk.out",
    "build": "tsc -p tsconfig.build.json",
    "eslint": "yarn eslint src",
    "prettier": "yarn run prettier:src",
    "prettier:src": "yarn prettier src --loglevel=warn",
    "watch": "tsc -w -p tsconfig.build.json",
    "clean:light": "rimraf dist tsconfig.build.tsbuildinfo",
    "clean:full": "yarn run clean:light && rimraf ./cdk.out"
  },
  "devDependencies": {
    "@types/node": "10.17.27",
    "@typescript-eslint/eslint-plugin": "^4.15.1",
    "@typescript-eslint/parser": "^4.15.1",
    "eslint": "^7.20.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-import-resolver-node": "^0.3.4",
    "eslint-plugin-import": "^2.22.1",
    "rimraf": "^3.0.2",
    "ts-node": "^9.0.0",
    "tslib": "^2.1.0",
    "typescript": "~3.9.7"
  },
  "dependencies": {
    "@aws-cdk/aws-codepipeline": "^1.90.1",
    "@aws-cdk/aws-codepipeline-actions": "^1.90.1",
    "@aws-cdk/core": "^1.90.1",
    "@aws-cdk/pipelines": "^1.90.1"
  }
}
