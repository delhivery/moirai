{
  "name": "@delhivery/moirai.atropos",
  "version": "0.1.0",
  "bin": "bin/atropos.js",
  "scripts": {
    "clean": "rimraf dist && rimraf cdk.out",
    "build": "tsc -p tsconfig.build.json && npx cdk synth",
    "watch": "tsc -w -p tsconfig.build.json",
    "synth": "npx cdk synth",
    "cdk": "cdk",
    "clean:light": "rimraf dist tsconfig.build.tsbuildinfo",
    "clean:full": "yarn run clean:light && rimraf ./cdk.out"
  },
  "devDependencies": {
    "@aws-cdk/assert": "1.90.1",
    "@types/node": "10.17.27",
    "@typescript-eslint/eslint-plugin": "^4.15.1",
    "@typescript-eslint/parser": "^4.15.1",
    "aws-cdk": "1.90.1",
    "eslint": "^7.20.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-import-resolver-node": "^0.3.4",
    "eslint-plugin-import": "^2.22.1",
    "rimraf": "^3.0.2",
    "ts-node": "^9.0.0",
    "tslib": "^2.1.0",
    "typescript": "~3.9.7"
  },
  "dependencies": {
    "@aws-cdk/aws-codebuild": "^1.90.1",
    "@aws-cdk/aws-codepipeline": "^1.90.1",
    "@aws-cdk/aws-codepipeline-actions": "^1.90.1",
    "@aws-cdk/aws-ecr": "^1.90.1",
    "@aws-cdk/aws-s3": "^1.90.1",
    "@aws-cdk/aws-ssm": "^1.90.1",
    "@aws-cdk/core": "1.90.1",
    "@aws-cdk/pipelines": "^1.90.1",
    "@delhivery/utilities": "workspace:packages/utils",
    "dotenv": "^8.2.0",
    "source-map-support": "^0.5.16"
  }
}
